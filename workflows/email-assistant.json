      "credentials": {
        "slackApi": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID",
          "name": "Slack API"
        }
      }
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a friendly, professional customer support agent for [Company Name], a SaaS platform.\n\nWrite a helpful reply to the customer's email. Rules:\n1. Address them by first name if available\n2. Acknowledge their specific issue — show you read it\n3. Provide a clear, actionable solution or next step\n4. Be concise — 3-5 sentences max\n5. End with an open offer to help further\n6. Sign off as 'The [Company] Support Team'\n\nTone: Warm but professional. Never robotic. Never over-apologetic.\nOutput the reply text only. No subject line, no metadata."
            },
            {
              "role": "user",
              "content": "Customer email:\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\nBody: {{ $json.body }}\n\nIssue summary: {{ $json.summary }}"
            }
          ]
        },
        "options": {
          "temperature": 0.7
        }
      },
      "name": "Generate Draft Reply",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1,
