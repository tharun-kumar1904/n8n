# ============================================================
# AI Email Assistant — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ---- n8n Login Credentials --------------------------------
# Used to log into the n8n dashboard at http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=change-this-to-a-strong-password

# ---- Encryption Key ----------------------------------------
# Used to encrypt all credentials stored in n8n
# Generate with: openssl rand -hex 32
# CRITICAL: If you lose this key, all stored credentials break
N8N_ENCRYPTION_KEY=paste-your-32-char-hex-here

# ---- Public URL --------------------------------------------
# Your n8n's public URL — used for webhooks and OAuth2 callbacks
# Local dev: http://localhost:5678
# Railway/Render: https://your-app.railway.app
WEBHOOK_URL=http://localhost:5678

# ---- PostgreSQL Database -----------------------------------
DB_USER=n8n_user
DB_PASSWORD=change-this-db-password-too

# ============================================================
# The following are configured INSIDE n8n as Credentials,
# NOT as environment variables. This is more secure because
# n8n encrypts them at rest.
#
# To add in n8n: Settings → Credentials → Add Credential
#
# 1. Gmail OAuth2
#    - Go to console.cloud.google.com
#    - Enable Gmail API
#    - Create OAuth2 credentials (Desktop app)
#    - Add Client ID + Secret to n8n
#
# 2. OpenAI API
#    - Go to platform.openai.com/api-keys
#    - Create a new key
#    - Add as "OpenAI API" credential in n8n
#
# 3. Slack API
#    - Go to api.slack.com/apps → Create App
#    - Add bot scopes: chat:write, channels:read
#    - Install to workspace, copy Bot Token
#    - Add as "Slack API" credential in n8n
#
# 4. Google Sheets OAuth2
#    - Reuse the same Google OAuth2 credential from Gmail
#    - Or create a Service Account for server-to-server auth
# ============================================================
